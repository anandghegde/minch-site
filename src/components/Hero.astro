---
import Wordmark from './Wordmark.astro';
import { DOWNLOAD_PATH, GITHUB_REPO_URL, EVENTS } from '../config';
import { getDmgDownloadCount } from '../lib/github';

// First-party download path (nginx 302 → GitHub .dmg). See docs/analytics-setup.md.
const downloadHref = DOWNLOAD_PATH;
const githubHref = GITHUB_REPO_URL;

// Real download count as social proof. Build-time only (skips dev to avoid
// hammering the GitHub API on every request); hides itself if unavailable.
// Only surface it once it's meaningful — a tiny number reads as *un*popular,
// so stay quiet below this floor.
const MIN_DOWNLOADS_TO_SHOW = 250;
const downloadCount = import.meta.env.PROD ? await getDmgDownloadCount() : null;
const downloadCountLabel =
  downloadCount !== null && downloadCount >= MIN_DOWNLOADS_TO_SHOW
    ? new Intl.NumberFormat('en-US').format(downloadCount)
    : null;
---
<section class="relative overflow-hidden">
  <!-- subtle radial glow behind the headline -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 opacity-50"
    style="background: radial-gradient(60% 50% at 50% 0%, rgba(61,123,255,0.20) 0%, rgba(18,18,18,0) 70%);"
  ></div>

  <div class="relative mx-auto max-w-5xl px-6 pt-20 pb-16 sm:pt-28 sm:pb-20 text-center">
    <div class="flex justify-center mb-10">
      <Wordmark size={36} />
    </div>

    <h1 class="mx-auto max-w-3xl text-4xl sm:text-6xl font-semibold tracking-tight leading-[1.05]">
      Your downloads,<br/>
      <span class="text-bolt-gradient">at the speed of light.</span>
    </h1>

    <p class="mx-auto mt-6 max-w-xl text-base sm:text-lg text-neutral-300">
      A keyboard-first macOS client for TorBox. Free. Bring your own API key.
    </p>

    <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href={downloadHref}
        data-umami-event={EVENTS.downloadMacos}
        class="inline-flex items-center gap-2 rounded-lg bg-bolt-gradient px-6 py-3 text-base font-semibold text-white shadow-lg shadow-bolt/30 transition hover:opacity-90 focus:outline-none focus:ring-2 focus:ring-aqua focus:ring-offset-2 focus:ring-offset-surface-primary"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M12 3v12m0 0l-4-4m4 4l4-4M5 21h14" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Download for macOS
      </a>
      <a
        href={githubHref}
        data-umami-event={EVENTS.viewGithubHero}
        class="inline-flex items-center gap-2 text-sm font-medium text-neutral-300 hover:text-white transition"
      >
        View on GitHub
        <span aria-hidden="true">→</span>
      </a>
    </div>

    <p class="mt-4 text-xs text-neutral-500">
      Requires macOS 14+ • Apple Silicon
    </p>
    {downloadCountLabel && (
      <p class="mt-2 text-xs text-neutral-500">
        {downloadCountLabel} downloads and counting
      </p>
    )}
  </div>
</section>
