---
// Frames screenshot content (passed via the default slot) in a rounded,
// shadowed card. Rendered as a single `role="img"` so assistive tech announces
// one descriptive label rather than any decorative UI inside.
//
// `chrome` adds a faux macOS traffic-light titlebar — useful for HTML mockups.
// For a real window capture (which already has its own chrome) leave it off.
interface Props {
  /** Accessible description of the framed screen. */
  label?: string;
  /** Title shown centered in the faux titlebar (only when `chrome`). */
  title?: string;
  /** Render the faux macOS titlebar. Off for real captures. */
  chrome?: boolean;
}
const { label = 'Application screenshot', title = 'Minch', chrome = false } = Astro.props;
---
<section class="mx-auto max-w-5xl px-6 pb-20">
  <div
    class="rounded-xl overflow-hidden border border-white/10 bg-surface-elevated shadow-2xl shadow-black/60"
    role="img"
    aria-label={label}
  >
    {chrome && (
      <!-- macOS traffic-light chrome -->
      <div class="relative flex items-center gap-2 px-4 py-3 border-b border-white/5 bg-surface-elevated/80">
        <span class="w-3 h-3 rounded-full bg-[#FF5F57]"></span>
        <span class="w-3 h-3 rounded-full bg-[#FEBC2E]"></span>
        <span class="w-3 h-3 rounded-full bg-[#28C840]"></span>
        <span class="pointer-events-none absolute inset-x-0 text-center text-xs font-medium text-neutral-400">
          {title}
        </span>
      </div>
    )}
    <!-- framed content -->
    <div class="bg-surface-primary">
      <slot />
    </div>
  </div>
</section>
