---
// Trust band reinforcing the privacy-first brand: the app keeps the user's
// TorBox key local and runs without accounts or telemetry.
---
<section class="mx-auto max-w-3xl px-6 pb-20">
  <div class="rounded-xl border border-white/5 bg-surface-elevated/60 p-6 sm:p-8 text-center">
    <div class="mx-auto mb-4 inline-flex h-10 w-10 items-center justify-center rounded-lg bg-bolt/10 text-bolt">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M12 3l7 3v5c0 4.5-3 7.6-7 9-4-1.4-7-4.5-7-9V6l7-3z" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" />
        <path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </div>
    <h2 class="text-xl sm:text-2xl font-semibold tracking-tight text-white">
      Your key. Your Mac. Your business.
    </h2>
    <p class="mx-auto mt-3 max-w-xl text-sm text-neutral-400 leading-relaxed">
      Minch talks straight to TorBox with the API key you provide — kept in your
      macOS Keychain, never on a Minch server (there isn't one). No account, no
      cookies, no tracking of what you move.
    </p>
  </div>
</section>
