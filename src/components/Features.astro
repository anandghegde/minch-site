---
import Feature from './Feature.astro';
---
<section class="mx-auto max-w-5xl px-6 pb-20">
  <h2 class="text-2xl sm:text-3xl font-semibold tracking-tight mb-8 text-center">
    Everything in one window
  </h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
    <Feature
      icon="plus"
      title="Add anything"
      body="Magnets, .torrent files, URLs, watch folders. Paste, drop, or queue — whatever's fastest."
    />
    <Feature
      icon="play"
      title="Stream or download"
      body="Play straight from TorBox or pull files into your local library. Your call, per torrent."
    />
    <Feature
      icon="search"
      title="Find anything"
      body="Full-text search with kind:, tag:, size:, and added: modifiers. Big libraries stay navigable."
    />
    <Feature
      icon="keyboard"
      title="Keyboard-first"
      body="⌘K command palette, ⌘N to add, ⌘R to refresh. Built for people who never touch the mouse."
    />
  </div>
</section>
