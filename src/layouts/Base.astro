---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Minch — TorBox client for macOS',
  description = 'A keyboard-first macOS client for TorBox. Free. Bring your own API key.',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://minch.app').toString();
const ogImage = new URL('/og-image.png', Astro.site ?? 'https://minch.app').toString();
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#121212" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body class="bg-surface-primary text-neutral-100 min-h-screen flex flex-col">
    <main class="flex-1">
      <slot />
    </main>
  </body>
</html>
