# Public site configuration — copy to `.env` and fill in.
# Everything here is PUBLIC_ (safe to ship in client markup). No secrets.
# All values are optional: defaults live in src/config.ts.

# Self-hosted Umami instance host (no trailing slash).
PUBLIC_ANALYTICS_HOST=https://analytics.minch.app

# Umami website ID — copy from the Umami dashboard after creating the
# `minch.app` website (Settings → Websites → … → Edit).
PUBLIC_UMAMI_WEBSITE_ID=

# Optional search-engine verification tokens. DNS TXT verification is
# preferred (see docs/analytics-setup.md); set these only if you must verify
# via a <meta> tag instead. Leave blank to emit no markup.
PUBLIC_GOOGLE_SITE_VERIFICATION=
PUBLIC_BING_SITE_VERIFICATION=
